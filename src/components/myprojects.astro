---
// MyProjects component

interface Project {
  name: string;
  description: string;
  status: 'Completado' | 'En desarrollo' | 'Planeado';
  tags: string[];
  tagColor: string;
  accentColor: string;
  image: string; // ruta relativa a /public (ej: /projectsimg/cedisj.png)
  codeUrl: string;
  webUrl: string;
}

const projects: Project[] = [
  {
    name: 'CEDISJ',
    description:
      'Repositorio para gestión documental de proyectos, monografías, prácticas, informes y eventos en tiempo real para las carreras de Sociología, Psicología y Derecho en la Universidad Popular del Cesar.',
    status: 'Completado',
    tags: ['React', 'Node.js', 'AWS', 'MongoDB', 'Firebase'],
    tagColor: 'bg-sky-100 text-sky-700',
    accentColor: 'indigo',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
  {
    name: 'GNEIS',
    description:
      'Plataforma web para la gestión integral del Hotel Neruda Mar: reservas, habitaciones, check-in / check-out, información física y facturación.',
    status: 'Completado',
    tags: ['React', 'Node.js', 'Supabase', 'SQL Server', 'Tailwind CSS'],
    tagColor: 'bg-emerald-100 text-emerald-700',
    accentColor: 'emerald',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
  {
    name: 'Mr. Chofer',
    description:
      'Aplicación móvil para solicitar motocicletas en encargos y traslados, con mapas interactivos, rutas en tiempo real y roles diferenciados: Conductor, Usuario y Administrador.',
    status: 'Completado',
    tags: ['React Native', 'Node.js', 'Maps API', 'Socket.io'],
    tagColor: 'bg-orange-100 text-orange-700',
    accentColor: 'orange',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
  {
    name: 'KENWA',
    description:
      'Web y app móvil para la gestión de tiempos de descanso y niveles de estrés laboral, con indicadores, cronómetros y gráficas interactivas para promover un ambiente de trabajo saludable.',
    status: 'Completado',
    tags: ['React', 'React Native','Astro', 'Tailwind CSS', 'Chart.js', 'Supabase'],
    tagColor: 'bg-purple-100 text-purple-700',
    accentColor: 'purple',
    image: '',
    codeUrl: 'https://github.com/Gsus07/kenwa-pages',
    webUrl: 'https://kenwa.pages.dev/',
  },
  {
    name: 'Validador CUVAPP',
    description:
      'Plataforma web de uso institucional para la validación de medicamentos ante el INVIMA, con visualización de estados actualizados por producto.',
    status: 'Completado',
    tags: ['React', 'Astro', 'Tailwind CSS', 'SQL Server', 'Pandas'],
    tagColor: 'bg-sky-100 text-sky-700',
    accentColor: 'sky',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
  {
    name: 'TINCHAT',
    description:
      'Red social enfocada en videojuegos para un círculo cercano: muro principal, submuros por categorías, comentarios, reacciones, respuestas, temas, estilos personalizados y subida de imágenes.',
    status: 'Completado',
    tags: ['React', 'Supabase', 'Supabase Storage', 'Tailwind CSS'],
    tagColor: 'bg-violet-100 text-violet-700',
    accentColor: 'violet',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
  {
    name: 'MERIAPP',
    description:
      'Aplicación web para gestionar las meriendas de un equipo de oficina: inventario de productos, registro de consumos y control de presupuestos.',
    status: 'Completado',
    tags: ['React', 'Supabase', 'SQL', 'Tailwind CSS'],
    tagColor: 'bg-yellow-100 text-yellow-700',
    accentColor: 'yellow',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
  {
    name: 'REGQRAPP',
    description:
      'Aplicación para el registro de ingresos y personal vinculado a vehículos en la Línea 1 del Metro de Bogotá. Genera tickets y códigos QR que, al escanearse, muestran la información del propietario y vehículo, y permiten registrar salidas y nuevos ingresos.',
    status: 'Completado',
    tags: ['React', 'Firebase', 'QR Code', 'Tailwind CSS'],
    tagColor: 'bg-rose-100 text-rose-700',
    accentColor: 'rose',
    image: '',
    codeUrl: '#',
    webUrl: '#',
  },
];

const statusColors: Record<Project['status'], string> = {
  'Completado':    'bg-green-600',
  'En desarrollo': 'bg-indigo-500',
  'Planeado':      'bg-gray-400',
};

const accentStyles: Record<string, { hover: string; btn: string; outline: string; outlineHover: string }> = {
  indigo:  { hover: 'group-hover:text-indigo-600',  btn: 'from-indigo-500 to-purple-600',  outline: 'border-indigo-300 text-indigo-600',  outlineHover: 'hover:bg-indigo-50' },
  emerald: { hover: 'group-hover:text-emerald-600', btn: 'from-emerald-500 to-teal-600',   outline: 'border-emerald-300 text-emerald-600', outlineHover: 'hover:bg-emerald-50' },
  orange:  { hover: 'group-hover:text-orange-600',  btn: 'from-orange-500 to-red-500',     outline: 'border-orange-300 text-orange-600',   outlineHover: 'hover:bg-orange-50' },
  purple:  { hover: 'group-hover:text-purple-600',  btn: 'from-purple-500 to-indigo-600',  outline: 'border-purple-300 text-purple-600',   outlineHover: 'hover:bg-purple-50' },
  sky:     { hover: 'group-hover:text-sky-600',     btn: 'from-sky-500 to-blue-600',       outline: 'border-sky-300 text-sky-600',         outlineHover: 'hover:bg-sky-50' },
  yellow:  { hover: 'group-hover:text-yellow-600',  btn: 'from-yellow-400 to-orange-400',  outline: 'border-yellow-300 text-yellow-600',   outlineHover: 'hover:bg-yellow-50' },
  rose:    { hover: 'group-hover:text-rose-600',    btn: 'from-rose-500 to-pink-600',      outline: 'border-rose-300 text-rose-600',       outlineHover: 'hover:bg-rose-50' },
  violet:  { hover: 'group-hover:text-violet-600',  btn: 'from-violet-500 to-purple-600',  outline: 'border-violet-300 text-violet-600',   outlineHover: 'hover:bg-violet-50' },
};
---

<!-- Projects -->
<section id="projects" class="bg-gradient-to-br from-slate-50 to-indigo-50/40 py-24 relative overflow-hidden">
  <!-- Floating background particles -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="proj-particle proj-p1"></div>
    <div class="proj-particle proj-p2"></div>
    <div class="proj-particle proj-p3"></div>
    <div class="proj-particle proj-p4"></div>
    <div class="proj-particle proj-p5"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <h2 class="text-center text-3xl font-bold text-slate-800 sm:text-4xl scroll-animate">
      Mis Proyectos
    </h2>
    <p class="mt-2 text-center text-slate-600 scroll-animate" style="transition-delay:0.1s">
      Algunos de los trabajos en los que he estado trabajando
    </p>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project, i) => {
        const accent = accentStyles[project.accentColor];
        return (
          <div
            class="proj-card scroll-animate rounded-2xl border border-white/60 bg-white/70 backdrop-blur-md shadow-md transition-all duration-400 group overflow-hidden flex flex-col"
            style={`transition-delay: ${i * 0.1}s`}
          >

            <!-- Imagen del proyecto + overlay -->
            <div class="h-44 w-full bg-gradient-to-br from-slate-100 to-slate-200 overflow-hidden flex items-center justify-center relative">
              {project.image ? (
                <img
                  src={project.image}
                  alt={`Captura de ${project.name}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
              ) : (
                <span class="text-slate-400 text-sm select-none">Sin imagen aún</span>
              )}
              <!-- Hover overlay -->
              <div class="proj-overlay absolute inset-0 bg-gradient-to-t from-indigo-900/80 via-purple-800/40 to-transparent flex items-end justify-center pb-4 opacity-0 group-hover:opacity-100 transition-opacity duration-400">
                <span class="text-white text-xs font-semibold tracking-wide uppercase px-3 text-center">{project.name}</span>
              </div>
            </div>

            <!-- Contenido -->
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-center justify-between gap-2">
                <h3 class={`text-lg font-semibold text-slate-800 transition-colors duration-300 ${accent.hover}`}>
                  {project.name}
                </h3>
                <!-- Status badge with pulsing dot -->
                <span class={`flex items-center gap-1.5 rounded-full ${statusColors[project.status]} px-2 py-0.5 text-xs font-medium text-white shrink-0`}>
                  <span class="status-pulse-dot inline-block w-1.5 h-1.5 rounded-full bg-white/90"></span>
                  {project.status}
                </span>
              </div>

              <p class="mt-3 text-sm text-slate-600 flex-1">{project.description}</p>

              <div class="proj-tags mt-4 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class={`rounded-full ${project.tagColor} px-2 py-0.5 text-xs font-medium transition-transform duration-300`}>{tag}</span>
                ))}
              </div>

              <div class="mt-6 flex gap-3 items-center">
                {project.codeUrl && project.codeUrl !== '#' ? (
                  <a
                    href={project.codeUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ver código de ${project.name}`}
                    class={`rounded-full bg-gradient-to-r ${accent.btn} px-4 py-2 text-sm font-medium text-white shadow-lg transition-all duration-300 hover:-translate-y-1 hover:scale-105`}
                  >
                    Ver código
                  </a>
                ) : (
                  <span class="rounded-full bg-slate-100 border border-slate-200 px-4 py-2 text-sm font-medium text-slate-400 cursor-not-allowed select-none flex items-center gap-2">
                    <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                    </svg>
                    Privado
                  </span>
                )}
                {project.webUrl && project.webUrl !== '#' && (
                  <a
                    href={project.webUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Web de ${project.name}`}
                    class={`rounded-full border ${accent.outline} px-4 py-2 text-sm font-medium transition-all duration-300 hover:-translate-y-1 hover:scale-105 ${accent.outlineHover}`}
                  >
                    Web
                  </a>
                )}
              </div>
            </div>

          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ── Card glassmorphism hover ── */
  .proj-card {
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s ease;
  }
  .proj-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 28px 56px -10px rgba(99,102,241,0.22), 0 12px 24px -4px rgba(0,0,0,0.1);
  }

  /* ── Status pulsing dot ── */
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.6); opacity: 0.6; }
  }
  .status-pulse-dot {
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  /* ── Tags fan on hover ── */
  .proj-card:hover .proj-tags span {
    transform: translateY(-3px);
  }
  .proj-card:hover .proj-tags span:nth-child(odd) {
    transform: translateY(-5px) rotate(-1.5deg);
  }
  .proj-card:hover .proj-tags span:nth-child(even) {
    transform: translateY(-4px) rotate(1.5deg);
  }

  /* ── Floating background particles ── */
  .proj-particle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.12;
    filter: blur(40px);
  }
  @keyframes proj-float {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-30px) scale(1.08); }
  }
  .proj-p1 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, #818cf8, transparent);
    top: 5%; left: 5%;
    animation: proj-float 10s ease-in-out infinite;
  }
  .proj-p2 {
    width: 160px; height: 160px;
    background: radial-gradient(circle, #c084fc, transparent);
    top: 20%; right: 8%;
    animation: proj-float 14s ease-in-out infinite reverse;
  }
  .proj-p3 {
    width: 240px; height: 240px;
    background: radial-gradient(circle, #38bdf8, transparent);
    bottom: 10%; left: 30%;
    animation: proj-float 12s ease-in-out infinite 2s;
  }
  .proj-p4 {
    width: 120px; height: 120px;
    background: radial-gradient(circle, #f472b6, transparent);
    bottom: 20%; right: 15%;
    animation: proj-float 9s ease-in-out infinite 1s;
  }
  .proj-p5 {
    width: 100px; height: 100px;
    background: radial-gradient(circle, #a78bfa, transparent);
    top: 50%; left: 50%;
    animation: proj-float 16s ease-in-out infinite 3s;
  }
</style>
