---
// Experience component

interface Experience {
  period: string;
  role: string;
  company: string;
  gradient: string;   // clases Tailwind para badge y dot
  textColor: string;  // color del nombre de empresa
  dotColor: string;   // color de los bullets
  tasks: string[];
}

const experiences: Experience[] = [
  {
    period: '2025 - Actual',
    role: 'Desarrollador',
    company: 'OHI – Organización Humana Integral',
    gradient: 'from-purple-500 to-pink-500',
    textColor: 'text-purple-600',
    dotColor: 'bg-purple-500',
    tasks: [
      'Automatización de procesos para radicación de facturas (RIPS) con Python',
      'Desarrollo de aplicaciones web con React, Tailwind y Astro',
    ],
  },
  {
    period: '2024 - Actual',
    role: 'Ingeniero de Datos',
    company: 'OHI – Organización Humana Integral',
    gradient: 'from-indigo-500 to-purple-600',
    textColor: 'text-indigo-600',
    dotColor: 'bg-indigo-500',
    tasks: [
      'Limpieza y extracción de datos',
      'Creación de informes para análisis',
      'Gestión en SQL Server: extracción, tablas y funciones',
      'Tablas, funciones y disparadores en Supabase',
      'Procesamiento y visualización de datos con Python',
      'Automatización de reportes y análisis estadístico',
    ],
  },
  {
    period: '2023',
    role: 'Desarrollador Freelance',
    company: 'Proyecto independiente – Mr. Chofer',
    gradient: 'from-orange-500 to-red-500',
    textColor: 'text-orange-600',
    dotColor: 'bg-orange-500',
    tasks: [
      'Desarrollo de aplicación móvil con React Native para solicitud de motocicletas',
      'Integración de mapas interactivos y rutas en tiempo real',
      'Diseño de roles diferenciados: Conductor, Usuario y Administrador',
      'Gestión completa del proyecto de forma independiente',
    ],
  },
  {
    period: '2022 - 2023',
    role: 'Desarrollador (Proyecto Universitario)',
    company: 'Universidad Popular del Cesar (UPC)',
    gradient: 'from-sky-500 to-indigo-500',
    textColor: 'text-sky-600',
    dotColor: 'bg-sky-500',
    tasks: [
      'Desarrollo de página web y repositorio documental',
      'Uso de APIs de Google para seguridad',
      'Metodologías ágiles y trabajo colaborativo',
    ],
  },
];
---

<!-- Experiencia -->
<section id="experience" class="py-24 bg-gradient-to-br from-white via-slate-50 to-indigo-50 relative overflow-hidden">
  <!-- Elementos decorativos de fondo -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-10 right-10 w-40 h-40 bg-gradient-to-br from-indigo-100 to-purple-100 rounded-full opacity-30 animate-float-slow"></div>
    <div class="absolute bottom-20 left-20 w-32 h-32 bg-gradient-to-br from-purple-100 to-pink-100 rounded-full opacity-25 animate-float-medium"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 scroll-animate">
      <h2 class="text-3xl font-bold text-slate-800 sm:text-4xl mb-4">
        Experiencia Profesional
      </h2>
      <p class="text-slate-600 max-w-2xl mx-auto">
        Un recorrido por mi trayectoria profesional y los proyectos que han marcado mi crecimiento
      </p>
    </div>

    <!-- Timeline desktop -->
    <div class="relative max-w-4xl mx-auto hidden md:block">
      <!-- Línea central del timeline -->
      <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-indigo-500 via-purple-500 to-pink-500 rounded-full opacity-30"></div>

      {experiences.map((exp, i) => {
        const isRight = i % 2 === 0; // alterna: 0→derecha, 1→izquierda
        const delay = `${i * 0.2}s`;
        return (
          <div
            class={`timeline-item scroll-animate flex items-center ${i < experiences.length - 1 ? 'mb-12' : ''}`}
            style={`transition-delay: ${delay}`}
          >
            {/* Lado izquierdo */}
            {isRight ? (
              <div class="w-5/12 pr-8"></div>
            ) : (
              <div class="timeline-content w-5/12 pr-8 text-right">
                <div class="timeline-card bg-white/80 backdrop-blur-sm border border-white/20 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                  <div class={`timeline-badge bg-gradient-to-r ${exp.gradient} text-white px-4 py-2 rounded-full text-sm font-semibold mb-4 inline-block`}>
                    {exp.period}
                  </div>
                  <h3 class="text-xl font-bold text-slate-800 mb-2">{exp.role}</h3>
                  <p class={`${exp.textColor} font-medium mb-3`}>{exp.company}</p>
                  <ul class="text-slate-600 text-sm space-y-2">
                    {exp.tasks.map((task) => (
                      <li class="flex items-start gap-2 justify-end">
                        <span class="text-right">{task}</span>
                        <span class={`w-2 h-2 ${exp.dotColor} rounded-full mt-2 flex-shrink-0`}></span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}

            {/* Punto central */}
            <div class={`timeline-dot w-6 h-6 bg-gradient-to-r ${exp.gradient} rounded-full border-4 border-white shadow-lg z-10 flex-shrink-0`}></div>

            {/* Lado derecho */}
            {isRight ? (
              <div class="timeline-content w-5/12 pl-8">
                <div class="timeline-card bg-white/80 backdrop-blur-sm border border-white/20 rounded-2xl p-6 shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                  <div class={`timeline-badge bg-gradient-to-r ${exp.gradient} text-white px-4 py-2 rounded-full text-sm font-semibold mb-4 inline-block`}>
                    {exp.period}
                  </div>
                  <h3 class="text-xl font-bold text-slate-800 mb-2">{exp.role}</h3>
                  <p class={`${exp.textColor} font-medium mb-3`}>{exp.company}</p>
                  <ul class="text-slate-600 text-sm space-y-2">
                    {exp.tasks.map((task) => (
                      <li class="flex items-start gap-2">
                        <span class={`w-2 h-2 ${exp.dotColor} rounded-full mt-2 flex-shrink-0`}></span>
                        {task}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <div class="w-5/12 pl-8"></div>
            )}
          </div>
        );
      })}
    </div>

    <!-- Versión móvil del timeline -->
    <div class="block md:hidden space-y-8">
      {experiences.map((exp, i) => (
        <div
          class="timeline-card-mobile scroll-animate bg-white/80 backdrop-blur-sm border border-white/20 rounded-2xl p-6 shadow-lg"
          style={`transition-delay: ${i * 0.15}s`}
        >
          <div class={`timeline-badge bg-gradient-to-r ${exp.gradient} text-white px-4 py-2 rounded-full text-sm font-semibold mb-4 inline-block`}>
            {exp.period}
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2">{exp.role}</h3>
          <p class={`${exp.textColor} font-medium mb-3`}>{exp.company}</p>
          <ul class="text-slate-600 text-sm space-y-2">
            {exp.tasks.map((task) => (
              <li>• {task}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Estilos para el timeline de experiencia */
  .timeline-card {
    position: relative;
    overflow: hidden;
  }

  .timeline-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    transition: left 0.5s;
  }

  .timeline-card:hover::before {
    left: 100%;
  }

  .timeline-dot {
    position: relative;
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.7);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(99, 102, 241, 0);
    }
  }

  /* Responsive timeline */
  @media (max-width: 768px) {
    .timeline-item {
      display: none;
    }
  }

  /* Animaciones de flotación para elementos decorativos */
  @keyframes float-slow {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg);
    }
    50% { 
      transform: translateY(-20px) rotate(5deg);
    }
  }

  @keyframes float-medium {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg);
    }
    50% { 
      transform: translateY(-15px) rotate(-3deg);
    }
  }

  .animate-float-slow {
    animation: float-slow 6s ease-in-out infinite;
  }

  .animate-float-medium {
    animation: float-medium 4s ease-in-out infinite;
  }
</style>
