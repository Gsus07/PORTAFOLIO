---
// Hero Component
---

<!-- Hero -->
<section
  id="about"
  class="relative flex min-h-screen items-center bg-gradient-to-br from-indigo-500 via-purple-500 to-purple-600 py-32 text-white overflow-hidden"
  style="background: linear-gradient(120deg, #6366f1 0%, #a78bfa 50%, #9333ea 100%);"
>
  <!-- Aurora borealis -->
  <div class="aurora-layer aurora-1 absolute inset-0 pointer-events-none z-0"></div>
  <div class="aurora-layer aurora-2 absolute inset-0 pointer-events-none z-0"></div>
  <div class="aurora-layer aurora-3 absolute inset-0 pointer-events-none z-0"></div>

  <!-- Contenedor de partículas espaciales -->
  <div id="space-particles" class="absolute inset-0 pointer-events-none z-[1] overflow-hidden"></div>
  
  <!-- Figuras animadas fondo -->
  <div class="absolute inset-0 pointer-events-none z-0">
    <div class="bg-figura1 animate-figura1 absolute top-10 left-10 w-56 h-56 rounded-full opacity-30"></div>
    <div class="bg-figura2 animate-figura2 absolute bottom-0 right-32 w-72 h-72 rounded-full opacity-20"></div>
    <div class="bg-figura3 animate-figura3 absolute top-1/2 left-1/2 w-32 h-32 rounded-full opacity-25"></div>
    <!-- Cuadrados animados -->
    <div class="bg-cuadrado1 animate-cuadrado1 absolute top-24 right-10 w-10 h-10 opacity-30"></div>
    <div class="bg-cuadrado2 animate-cuadrado2 absolute bottom-32 left-32 w-8 h-8 opacity-25"></div>
    <!-- Triángulos animados -->
    <div class="triangulo1 animate-triangulo1 absolute top-1/3 left-1/4 w-0 h-0" style="border-left: 16px solid transparent; border-right: 16px solid transparent; border-bottom: 28px solid #fff; opacity:0.22;"></div>
    <div class="triangulo2 animate-triangulo2 absolute bottom-20 right-1/3 w-0 h-0" style="border-left: 10px solid transparent; border-right: 10px solid transparent; border-bottom: 18px solid #a5b4fc; opacity:0.18;"></div>
    <!-- Líneas cascada electrónica -->
    {Array.from({length: 18}).map((_, i) => (
      <div
        class={`cascada-linea animate-cascada${i%3+1}`}
        style={`left: ${6 + i*5.2}vw; top: -40px; height: ${60 + (i%3)*30}px;`}
      ></div>
    ))}
  </div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16"
    >
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left animate-fadein order-2 lg:order-1">
        <h1 class="text-4xl font-extrabold leading-tight sm:text-5xl md:text-6xl drop-shadow-xl">
          <span id="greeting-text"></span>
          <span
            class="block bg-gradient-to-r from-white to-sky-100 bg-clip-text text-transparent"
            id="name-text"
          ></span>
          <noscript>
            Hola, soy
            <span class="block bg-gradient-to-r from-white to-sky-100 bg-clip-text text-transparent">
              Jesús Andrés Cañaveral Florez
            </span>
          </noscript>
        </h1>

        <p class="mt-4 max-w-lg text-lg opacity-90" id="description-text"></p>
        <noscript>
          <p class="mt-4 max-w-lg text-lg opacity-90">Desarrollador y analista apasionado por crear experiencias digitales únicas</p>
        </noscript>

        <div class="mt-8 flex flex-wrap justify-center gap-4 lg:justify-start">
          <a
            href="https://github.com/Gsus07"
            target="_blank"
            class="flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium backdrop-blur-sm transition-all duration-300 hover:bg-white/30 hover:-translate-y-1 hover:scale-105 shadow-lg"
          >
            <img src="/img/github.png" alt="" aria-hidden="true" class="h-5 w-5" />
            GitHub
          </a>

          <a
            href="https://www.linkedin.com/in/jesus-cañaveral-gsus07"
            target="_blank"
            class="flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium backdrop-blur-sm transition-all duration-300 hover:bg-white/30 hover:-translate-y-1 hover:scale-105 shadow-lg"
          >
            <img src="/img/linkedin.png" alt="" aria-hidden="true" class="h-5 w-5" />
            LinkedIn
          </a>

          <a
            href="/cv/CV_JESUS_CAÑAVERAL.pdf"
            download
            aria-label="Descargar CV"
            class="cv-shimmer-btn flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-white shadow-xl transition-all duration-300 hover:-translate-y-1 hover:scale-105"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-8m0 8l-3-3m3 3l3-3M4 20h16"/>
            </svg>
            Descargar CV
          </a>
        </div>
      </div>

      <div class="flex justify-center animate-fadein-delay order-1 lg:order-2">
        <!-- Spinning gradient ring wrapper -->
        <div class="avatar-ring-wrapper relative flex items-center justify-center">
          <div class="avatar-spin-ring absolute rounded-full"></div>
          <div
            class="relative flex h-64 w-64 items-center justify-center rounded-full border-2 border-white/20 bg-white/10 backdrop-blur-sm lg:h-80 lg:w-80 shadow-2xl transition-transform duration-300 hover:scale-105 group"
        >
          <div class="profile-img-container group">
            <img
              src="/img/YO.jpeg"
              alt="Jesús Cañaveral"
              class="profile-img front h-56 w-56 rounded-full object-cover lg:h-72 lg:w-72 shadow-lg transition-transform duration-700"
            />
            <img
              src="/img/perf.jpeg"
              alt="Jesús Cañaveral — foto alternativa"
              class="profile-img back h-56 w-56 rounded-full object-cover lg:h-72 lg:w-72 shadow-lg transition-transform duration-700"
            />
          </div>
          <!-- Mensaje tipo chat -->
          <div id="chat-bubble" class="absolute left-1/2 -translate-x-1/2 -top-8 opacity-0 group-hover:opacity-100 group-hover:-top-16 transition-all duration-300 pointer-events-none z-20">
            <div class="bg-white text-indigo-600 px-4 py-2 rounded-2xl shadow-lg border border-indigo-100 text-sm font-semibold flex items-center gap-2 animate-chat-bounce">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h15a2 2 0 0 1 2 2v10Z" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Hola
            </div>
          </div>
        </div>
        </div><!-- /avatar-ring-wrapper -->
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 z-10 select-none pointer-events-none">
    <span class="text-white/70 text-xs tracking-widest uppercase">Scroll</span>
    <svg class="scroll-arrow w-5 h-5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<style>
  /* ── Aurora borealis ── */
  @keyframes aurora1 {
    0%   { transform: translate(0, 0)    scale(1)    hue-rotate(0deg); }
    33%  { transform: translate(60px, -40px) scale(1.15) hue-rotate(40deg); }
    66%  { transform: translate(-40px, 30px) scale(0.9) hue-rotate(-30deg); }
    100% { transform: translate(0, 0)    scale(1)    hue-rotate(0deg); }
  }
  @keyframes aurora2 {
    0%   { transform: translate(0, 0)    scale(1)    hue-rotate(0deg); }
    50%  { transform: translate(-80px, 60px) scale(1.2) hue-rotate(60deg); }
    100% { transform: translate(0, 0)    scale(1)    hue-rotate(0deg); }
  }
  @keyframes aurora3 {
    0%   { transform: translate(0, 0)    scale(1.1) hue-rotate(0deg); }
    40%  { transform: translate(50px, 80px)  scale(0.85) hue-rotate(-50deg); }
    100% { transform: translate(0, 0)    scale(1.1) hue-rotate(0deg); }
  }
  .aurora-layer {
    position: absolute;
    inset: -30%;
    border-radius: 50%;
    mix-blend-mode: screen;
    pointer-events: none;
    opacity: 0.18;
    filter: blur(60px);
  }
  .aurora-1 {
    background: radial-gradient(ellipse 80% 50% at 30% 40%, #818cf8 0%, transparent 70%);
    animation: aurora1 12s ease-in-out infinite;
  }
  .aurora-2 {
    background: radial-gradient(ellipse 60% 70% at 70% 60%, #c084fc 0%, transparent 70%);
    animation: aurora2 16s ease-in-out infinite;
  }
  .aurora-3 {
    background: radial-gradient(ellipse 70% 40% at 50% 20%, #38bdf8 0%, transparent 70%);
    animation: aurora3 20s ease-in-out infinite;
  }

  /* ── Spinning avatar ring ── */
  .avatar-ring-wrapper {
    width: 17rem;
    height: 17rem;
  }
  @media (min-width: 1024px) {
    .avatar-ring-wrapper { width: 21rem; height: 21rem; }
  }
  @keyframes spin-ring {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .avatar-spin-ring {
    inset: -6px;
    width: calc(100% + 12px);
    height: calc(100% + 12px);
    background: conic-gradient(#6366f1, #a78bfa, #ec4899, #38bdf8, #6366f1);
    animation: spin-ring 4s linear infinite;
    filter: blur(2px);
    opacity: 0.85;
  }

  /* ── CV shimmer button ── */
  @keyframes shimmer-btn {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
  }
  .cv-shimmer-btn {
    background: linear-gradient(90deg,
      #6366f1 0%, #a78bfa 25%, #ffffff88 50%, #a78bfa 75%, #6366f1 100%
    );
    background-size: 200% auto;
    animation: shimmer-btn 2.4s linear infinite;
  }

  /* ── Scroll indicator ── */
  @keyframes bounce-arrow {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50%       { transform: translateY(6px); opacity: 1; }
  }
  .scroll-indicator { animation: none; }
  .scroll-arrow {
    animation: bounce-arrow 1.4s ease-in-out infinite;
  }

  /* ── Letter reveal ── */
  .letter-reveal {
    display: inline-block;
    opacity: 0;
    transform: translateY(16px);
    animation: letter-in 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes letter-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .profile-img-container {
    position: relative;
    width: 100%;
    height: 100%;
    perspective: 1200px;
  }
  .profile-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    transition: transform 0.7s cubic-bezier(.4,0,.2,1);
  }
  .profile-img.front {
    z-index: 2;
    transform: rotateY(0deg);
  }
  .profile-img.back {
    z-index: 1;
    transform: rotateY(180deg);
  }
  .profile-img-container:hover .profile-img.front {
    transform: rotateY(180deg);
  }
  .profile-img-container:hover .profile-img.back {
    transform: rotateY(0deg);
  }
  .profile-img-container.touch-flip .profile-img.front {
    transform: rotateY(180deg);
  }
  .profile-img-container.touch-flip .profile-img.back {
    transform: rotateY(0deg);
  }
  @keyframes fadein {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-fadein {
    animation: fadein 1.2s cubic-bezier(.4,0,.2,1) both;
  }
  .animate-fadein-delay {
    animation: fadein 1.8s cubic-bezier(.4,0,.2,1) both;
  }
  .chat-visible {
    opacity: 1;
    top: -4rem;
  }
  .bg-figura1 {
    background: radial-gradient(circle at 30% 30%, #fff 60%, #a5b4fc 100%);
  }
  .bg-figura2 {
    background: radial-gradient(circle at 70% 70%, #fff 50%, #c4b5fd 100%);
  }
  .bg-figura3 {
    background: radial-gradient(circle at 50% 50%, #fff 70%, #7dd3fc 100%);
  }
  .bg-cuadrado1 {
    background: #fff;
    border-radius: 0.25rem;
  }
  .bg-cuadrado2 {
    background: #a5b4fc;
    border-radius: 0.25rem;
  }
  .triangulo1 {
    /* El triángulo se crea con border en el style inline */
  }
  .triangulo2 {
    /* El triángulo se crea con border en el style inline */
  }
  @keyframes figura1 {
    0% { transform: translateY(0) scale(1); }
    50% { transform: translateY(40px) scale(1.08); }
    100% { transform: translateY(0) scale(1); }
  }
  @keyframes figura2 {
    0% { transform: translateX(0) scale(1); }
    50% { transform: translateX(-60px) scale(1.12); }
    100% { transform: translateX(0) scale(1); }
  }
  @keyframes figura3 {
    0% { transform: scale(1) rotate(0deg); }
    50% { transform: scale(1.15) rotate(12deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  @keyframes cuadrado1 {
    0% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(10deg); }
    100% { transform: translateY(0) rotate(0deg); }
  }
  @keyframes cuadrado2 {
    0% { transform: translateX(0) rotate(0deg); }
    50% { transform: translateX(18px) rotate(-8deg); }
    100% { transform: translateX(0) rotate(0deg); }
  }
  @keyframes triangulo1 {
    0% { transform: scale(1) translateY(0); }
    50% { transform: scale(1.12) translateY(-12px); }
    100% { transform: scale(1) translateY(0); }
  }
  @keyframes triangulo2 {
    0% { transform: scale(1) translateX(0); }
    50% { transform: scale(1.08) translateX(14px); }
    100% { transform: scale(1) translateX(0); }
  }
  .animate-figura1 {
    animation: figura1 7s ease-in-out infinite;
  }
  .animate-figura2 {
    animation: figura2 9s ease-in-out infinite;
  }
  .animate-figura3 {
    animation: figura3 11s ease-in-out infinite;
  }
  .animate-cuadrado1 {
    animation: cuadrado1 6s ease-in-out infinite;
  }
  .animate-cuadrado2 {
    animation: cuadrado2 8s ease-in-out infinite;
  }
  .animate-triangulo1 {
    animation: triangulo1 7s ease-in-out infinite;
  }
  .animate-triangulo2 {
    animation: triangulo2 9s ease-in-out infinite;
  }
  @keyframes chat-bounce {
    0% { transform: scale(0.8) translateY(10px); opacity: 0; }
    60% { transform: scale(1.05) translateY(-2px); opacity: 1; }
    100% { transform: scale(1) translateY(0); opacity: 1; }
  }
  .animate-chat-bounce {
    animation: chat-bounce 0.7s cubic-bezier(.4,0,.2,1) both;
  }
  /* Líneas cascada electrónica */
  .cascada-linea {
    position: absolute;
    width: 2px;
    background: linear-gradient(180deg, #fff 0%, #a5b4fc 80%, transparent 100%);
    opacity: 0.18;
    border-radius: 1px;
    z-index: 1;
    pointer-events: none;
  }
  @keyframes cascada1 {
    0% { top: -40px; opacity: 0.18; }
    10% { opacity: 0.28; }
    80% { opacity: 0.28; }
    100% { top: 100vh; opacity: 0; }
  }
  @keyframes cascada2 {
    0% { top: -40px; opacity: 0.18; }
    20% { opacity: 0.32; }
    70% { opacity: 0.32; }
    100% { top: 100vh; opacity: 0; }
  }
  @keyframes cascada3 {
    0% { top: -40px; opacity: 0.18; }
    15% { opacity: 0.24; }
    85% { opacity: 0.24; }
    100% { top: 100vh; opacity: 0; }
  }
  .animate-cascada1 {
    animation: cascada1 3.8s linear infinite;
  }
  .animate-cascada2 {
    animation: cascada2 4.6s linear infinite;
  }
  .animate-cascada3 {
    animation: cascada3 5.2s linear infinite;
  }

  /* Sistema de partículas espaciales */
  .space-particle {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    z-index: 10000;
  }

  /* Estrellas pequeñas */
  .star-small {
    width: 6px;
    height: 6px;
    background: #ffffff;
    box-shadow: 0 0 20px #ffffff, 0 0 40px #ffffff;
    animation: twinkle 3s infinite ease-in-out;
    z-index: 10;
  }

  /* Estrellas medianas */
  .star-medium {
    width: 8px;
    height: 8px;
    background: #a78bfa;
    box-shadow: 0 0 25px #a78bfa, 0 0 50px #a78bfa;
    animation: twinkle 2.5s infinite ease-in-out;
    z-index: 10;
  }

  /* Estrellas grandes */
  .star-large {
    width: 10px;
    height: 10px;
    background: #60a5fa;
    box-shadow: 0 0 30px #60a5fa, 0 0 60px #60a5fa;
    animation: twinkle 2s infinite ease-in-out;
    z-index: 10;
  }

  /* Planetas pequeños */
  .planet-small {
    width: 8px;
    height: 8px;
    background: linear-gradient(45deg, #f59e0b, #d97706);
    box-shadow: 0 0 15px rgba(245, 158, 11, 0.5);
    animation: float-planet 8s infinite ease-in-out;
  }

  /* Animaciones */
  @keyframes twinkle {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  @keyframes float-planet {
    0%, 100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(180deg);
    }
  }

  @keyframes comet-trail {
    0% {
      transform: translateX(-100vw) translateY(100vh) rotate(-45deg);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translateX(100vw) translateY(-100vh) rotate(-45deg);
      opacity: 0;
    }
  }

  @keyframes nebula-drift {
    0%, 100% {
      transform: translateX(0px) translateY(0px) scale(1);
      opacity: 0.3;
    }
    25% {
      transform: translateX(30px) translateY(-20px) scale(1.1);
      opacity: 0.5;
    }
    50% {
      transform: translateX(-20px) translateY(-40px) scale(0.9);
      opacity: 0.4;
    }
    75% {
      transform: translateX(-30px) translateY(20px) scale(1.05);
      opacity: 0.6;
    }
  }

  /* Movimiento de partículas */
  .particle-float-1 {
    animation: particle-float-1 12s infinite ease-in-out;
  }

  .particle-float-2 {
    animation: particle-float-2 15s infinite ease-in-out;
  }

  .particle-float-3 {
    animation: particle-float-3 18s infinite ease-in-out;
  }

  @keyframes particle-float-1 {
    0%, 100% {
      transform: translateY(0px) translateX(0px);
    }
    33% {
      transform: translateY(-30px) translateX(20px);
    }
    66% {
      transform: translateY(20px) translateX(-15px);
    }
  }

  @keyframes particle-float-2 {
    0%, 100% {
      transform: translateY(0px) translateX(0px);
    }
    25% {
      transform: translateY(25px) translateX(-20px);
    }
    50% {
      transform: translateY(-20px) translateX(30px);
    }
    75% {
      transform: translateY(15px) translateX(-10px);
    }
  }

  @keyframes particle-float-3 {
    0%, 100% {
      transform: translateY(0px) translateX(0px);
    }
    20% {
      transform: translateY(-25px) translateX(15px);
    }
    40% {
      transform: translateY(30px) translateX(-25px);
    }
    60% {
      transform: translateY(-15px) translateX(20px);
    }
    80% {
      transform: translateY(20px) translateX(-30px);
    }
  }
</style>

<script>
  // Sistema de partículas espaciales
  function createSpaceParticles() {
    const container = document.getElementById('space-particles');
    if (!container) {
      console.log('Container space-particles no encontrado');
      return;
    }

    console.log('Creando partículas espaciales...');

    // Limpiar partículas existentes
    container.innerHTML = '';

    const particleTypes = [
      { class: 'star-small', count: 20 },
      { class: 'star-medium', count: 15 },
      { class: 'star-large', count: 10 },
      { class: 'planet-small', count: 5 },
      { class: 'planet-medium', count: 3 },
      { class: 'comet', count: 2 },
      { class: 'nebula', count: 2 }
    ];

    particleTypes.forEach(type => {
      console.log(`Creando ${type.count} partículas de tipo ${type.class}`);
      for (let i = 0; i < type.count; i++) {
        const particle = document.createElement('div');
        
        // Posición aleatoria
        const x = Math.random() * 100;
        const y = Math.random() * 100;
        
        // Estilos base para todas las partículas
        let baseStyles = `
          position: absolute;
          left: ${x}%;
          top: ${y}%;
          border-radius: 50%;
          pointer-events: none;
          z-index: 2;
        `;
        
        // Estilos específicos según el tipo
        let specificStyles = '';
        let animationName = 'twinkle';
        
        switch(type.class) {
          case 'star-small':
            specificStyles = `
              width: 4px;
              height: 4px;
              background: #ffffff;
              box-shadow: 0 0 15px #ffffff, 0 0 30px #ffffff;
            `;
            break;
          case 'star-medium':
            specificStyles = `
              width: 6px;
              height: 6px;
              background: #a78bfa;
              box-shadow: 0 0 20px #a78bfa, 0 0 40px #a78bfa;
            `;
            break;
          case 'star-large':
            specificStyles = `
              width: 8px;
              height: 8px;
              background: #60a5fa;
              box-shadow: 0 0 25px #60a5fa, 0 0 50px #60a5fa;
            `;
            break;
          case 'planet-small':
            specificStyles = `
              width: 10px;
              height: 10px;
              background: linear-gradient(45deg, #f59e0b, #d97706);
              box-shadow: 0 0 20px rgba(245, 158, 11, 0.7);
            `;
            animationName = 'float-planet';
            break;
          case 'planet-medium':
            specificStyles = `
              width: 14px;
              height: 14px;
              background: linear-gradient(45deg, #8b5cf6, #7c3aed);
              box-shadow: 0 0 25px rgba(139, 92, 246, 0.7);
            `;
            animationName = 'float-planet';
            break;
          case 'comet':
            specificStyles = `
              width: 6px;
              height: 6px;
              background: #fbbf24;
              box-shadow: 0 0 15px #fbbf24;
            `;
            animationName = 'comet-trail';
            break;
          case 'nebula':
            specificStyles = `
              width: 30px;
              height: 30px;
              background: radial-gradient(circle, rgba(167, 139, 250, 0.4) 0%, rgba(167, 139, 250, 0.2) 50%, transparent 100%);
            `;
            animationName = 'nebula-drift';
            break;
        }
        
        // Aplicar todos los estilos
        particle.style.cssText = baseStyles + specificStyles + `
          animation: ${animationName} ${2 + Math.random() * 3}s infinite ease-in-out;
          animation-delay: ${Math.random() * 5}s;
        `;
        
        // Para cometas, agregar dirección aleatoria
        if (type.class === 'comet') {
          const angle = Math.random() * 360;
          particle.style.transform = `rotate(${angle}deg)`;
          particle.style.animationDelay = `${Math.random() * 15}s`;
        }

        container.appendChild(particle);
        console.log(`Partícula ${type.class} creada en ${x}%, ${y}%`);
      }
    });

    console.log(`Total de partículas creadas: ${container.children.length}`);

    // Crear cometas periódicos
    setInterval(() => {
      if (Math.random() < 0.3) { // 30% de probabilidad cada 8 segundos
        createComet();
      }
    }, 8000);
  }

  function createComet() {
    const container = document.getElementById('space-particles');
    if (!container) return;

    const comet = document.createElement('div');
    comet.className = 'space-particle comet';
    
    // Posición inicial aleatoria en los bordes
    const side = Math.floor(Math.random() * 4);
    switch(side) {
      case 0: // Top
        comet.style.left = `${Math.random() * 100}%`;
        comet.style.top = '-10px';
        break;
      case 1: // Right
        comet.style.left = '110%';
        comet.style.top = `${Math.random() * 100}%`;
        break;
      case 2: // Bottom
        comet.style.left = `${Math.random() * 100}%`;
        comet.style.top = '110%';
        break;
      case 3: // Left
        comet.style.left = '-10px';
        comet.style.top = `${Math.random() * 100}%`;
        break;
    }

    container.appendChild(comet);

    // Remover el cometa después de la animación
    setTimeout(() => {
      if (comet.parentNode) {
        comet.parentNode.removeChild(comet);
      }
    }, 15000);
  }

  // Efecto de escritura letra por letra
  function typeWriter(elementId: string, text: string, speed: number = 100, delay: number = 0) {
    return new Promise<void>((resolve) => {
      setTimeout(() => {
        const element = document.getElementById(elementId);
        if (!element) {
          resolve();
          return;
        }
        
        let i = 0;
        element.textContent = '';
        
        function type() {
          if (i < text.length) {
            if (element) {
              element.textContent += text.charAt(i);
            }
            i++;
            setTimeout(type, speed);
          } else {
            resolve();
          }
        }
        
        type();
      }, delay);
    });
  }

  // Inicializar efectos cuando se carga la página
  document.addEventListener('DOMContentLoaded', async () => {
    createSpaceParticles();
    await typeWriter('greeting-text', 'Hola, soy', 80, 500);

    // Letter-by-letter reveal for the name
    const nameEl = document.getElementById('name-text');
    const name = 'Jesús Andrés Cañaveral Florez';
    if (nameEl) {
      nameEl.innerHTML = '';
      [...name].forEach((char, idx) => {
        const span = document.createElement('span');
        span.className = 'letter-reveal';
        span.style.animationDelay = `${idx * 0.045}s`;
        span.textContent = char === ' ' ? '\u00A0' : char;
        nameEl.appendChild(span);
      });
    }

    await new Promise(r => setTimeout(r, name.length * 45 + 400));
    await typeWriter('description-text', 'Desarrollador y analista apasionado por crear experiencias digitales únicas', 40, 0);

    const isCoarse = window.matchMedia('(pointer: coarse)').matches;
    const profileContainer = document.querySelector('.profile-img-container');
    const chatBubble = document.getElementById('chat-bubble');
    if (isCoarse && profileContainer) {
      profileContainer.addEventListener('click', () => {
        const flipped = profileContainer.classList.toggle('touch-flip');
        if (chatBubble) {
          chatBubble.classList.toggle('chat-visible', flipped);
        }
      });
    }
  });

  // Recrear partículas cuando se redimensiona la ventana
  window.addEventListener('resize', () => {
    setTimeout(createSpaceParticles, 100);
  });
</script>