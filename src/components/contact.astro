---
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<!-- Contact -->
<section id="contact" class="py-24 bg-gradient-to-br from-slate-50 to-indigo-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-center text-3xl font-bold text-slate-800 sm:text-4xl scroll-animate">
      Contacto
    </h2>
    <p class="mt-2 text-center text-slate-600 scroll-animate" style="transition-delay:0.1s">
      ¿Tienes un proyecto en mente? ¡Hablemos!
    </p>

    <div class="mt-12 grid gap-12 lg:grid-cols-2">
      <div class="space-y-6 scroll-animate-left">
        <!-- Ubicación -->
        <div class="contact-info-card flex items-start gap-4 rounded-2xl bg-white p-4 shadow-md" style="--bounce-delay: 0s">
          <div
            class="contact-icon-wrap flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 text-white"
          >
            <svg
              class="h-6 w-6"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-800">Ubicación</h3>
            <p class="text-sm text-slate-600">Valledupar, Cesar, Colombia</p>
          </div>
        </div>

        <!-- Email -->
        <div class="contact-info-card flex items-start gap-4 rounded-2xl bg-white p-4 shadow-md" style="--bounce-delay: 0.2s">
          <div
            class="contact-icon-wrap flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 text-white"
          >
            <svg
              class="h-6 w-6"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-800">Email</h3>
            <p class="text-sm text-slate-600">jesuscafo15@gmail.com</p>
          </div>
        </div>

        <!-- Teléfono -->
        <div class="contact-info-card flex items-start gap-4 rounded-2xl bg-white p-4 shadow-md" style="--bounce-delay: 0.4s">
          <div
            class="contact-icon-wrap flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 text-white"
          >
            <svg
              class="h-6 w-6"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 ..."/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-800">Teléfono</h3>
            <p class="text-sm text-slate-600">+573046142863</p>
          </div>
        </div>
      </div>

      <!-- Formulario -->
      <form id="contact-form" class="space-y-6 rounded-2xl bg-white p-6 shadow-md scroll-animate-right" autocomplete="off">
        <input type="hidden" name="access_key" value={web3FormsKey} />
        <input type="hidden" name="subject" value="Nuevo mensaje desde tu portafolio" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <!-- Canvas confetti (hidden, shown on success) -->
        <canvas id="confetti-canvas" class="fixed inset-0 pointer-events-none z-[200] hidden" aria-hidden="true"></canvas>

        <div class="float-field">
          <input
            type="text"
            name="name"
            id="f-name"
            placeholder=" "
            required
            class="float-input w-full rounded-lg border border-slate-200 px-3 pt-5 pb-2 text-sm focus:border-indigo-500 focus:outline-none transition-all duration-300"
          />
          <label for="f-name" class="float-label">Tu nombre</label>
        </div>
        <div class="float-field">
          <input
            type="email"
            name="email"
            id="f-email"
            placeholder=" "
            required
            class="float-input w-full rounded-lg border border-slate-200 px-3 pt-5 pb-2 text-sm focus:border-indigo-500 focus:outline-none transition-all duration-300"
          />
          <label for="f-email" class="float-label">Tu email</label>
        </div>
        <div class="float-field">
          <input
            type="text"
            name="asunto"
            id="f-asunto"
            placeholder=" "
            required
            class="float-input w-full rounded-lg border border-slate-200 px-3 pt-5 pb-2 text-sm focus:border-indigo-500 focus:outline-none transition-all duration-300"
          />
          <label for="f-asunto" class="float-label">Asunto</label>
        </div>
        <div class="float-field">
          <textarea
            name="message"
            id="f-message"
            rows="5"
            placeholder=" "
            required
            class="float-input w-full rounded-lg border border-slate-200 px-3 pt-5 pb-2 text-sm focus:border-indigo-500 focus:outline-none transition-all duration-300"
          ></textarea>
          <label for="f-message" class="float-label">Tu mensaje</label>
        </div>
        <div id="form-status" class="hidden text-center text-sm font-semibold py-2 px-4 rounded-lg"></div>
        <button
          type="submit"
          aria-label="Enviar mensaje de contacto"
          class="ripple-btn relative overflow-hidden w-full rounded-full bg-gradient-to-r from-indigo-500 to-purple-600 py-3 text-sm font-semibold text-white shadow-lg transition-all duration-300 hover:-translate-y-1 hover:scale-105 glow-pulse"
        >
          Enviar mensaje
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  /* ── Floating label fields ── */
  .float-field {
    position: relative;
  }
  .float-label {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.875rem;
    color: #94a3b8;
    pointer-events: none;
    transition: top 0.2s ease, font-size 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  /* Textarea: label starts near the top */
  .float-field textarea ~ .float-label {
    top: 1.1rem;
    transform: none;
  }
  .float-input:focus ~ .float-label,
  .float-input:not(:placeholder-shown) ~ .float-label {
    top: 0.35rem;
    transform: none;
    font-size: 0.7rem;
    color: #6366f1;
  }
  .float-field textarea.float-input:focus ~ .float-label,
  .float-field textarea.float-input:not(:placeholder-shown) ~ .float-label {
    top: 0.2rem;
    font-size: 0.7rem;
    color: #6366f1;
  }

  /* ── Ripple button ── */
  .ripple-btn .ripple-circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    transform: scale(0);
    animation: ripple-expand 0.6s linear;
    pointer-events: none;
  }
  @keyframes ripple-expand {
    to { transform: scale(4); opacity: 0; }
  }

  /* ── Icon bounce ── */
  @keyframes icon-bounce {
    0%, 100% { transform: translateY(0); }
    40%       { transform: translateY(-6px); }
    60%       { transform: translateY(-3px); }
  }
  .contact-icon-wrap {
    animation: icon-bounce 2.6s ease-in-out infinite;
    animation-delay: var(--bounce-delay, 0s);
  }
</style>

<script>
  // ── Ripple effect on submit button ──
  document.querySelector<HTMLButtonElement>('.ripple-btn')?.addEventListener('click', (e: MouseEvent) => {
    const btn = e.currentTarget as HTMLButtonElement;
    const rect = btn.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height);
    const x = e.clientX - rect.left - size / 2;
    const y = e.clientY - rect.top  - size / 2;
    const circle = document.createElement('span');
    circle.className = 'ripple-circle';
    circle.style.cssText = `width:${size}px;height:${size}px;left:${x}px;top:${y}px`;
    btn.appendChild(circle);
    circle.addEventListener('animationend', () => circle.remove());
  });

  // ── Confetti ──
  function launchConfetti() {
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    canvas.classList.remove('hidden');
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const ctx = canvas.getContext('2d')!;
    const colors = ['#6366f1','#a78bfa','#ec4899','#38bdf8','#f59e0b','#10b981'];
    const particles = Array.from({length: 50}, () => ({
      x: Math.random() * canvas.width,
      y: -10,
      r: 4 + Math.random() * 6,
      d: 1 + Math.random() * 3,
      color: colors[Math.floor(Math.random() * colors.length)],
      tilt: Math.random() * 10 - 5,
      tiltAngle: 0,
      tiltSpeed: 0.05 + Math.random() * 0.1,
    }));
    let frame = 0;
    function draw() {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      particles.forEach(p => {
        p.tiltAngle += p.tiltSpeed;
        p.y += p.d;
        p.tilt = Math.sin(p.tiltAngle) * 12;
        ctx.beginPath();
        ctx.lineWidth = p.r;
        ctx.strokeStyle = p.color;
        ctx.moveTo(p.x + p.tilt, p.y);
        ctx.lineTo(p.x + p.tilt + p.r * 0.5, p.y + p.r);
        ctx.stroke();
      });
      frame++;
      if (frame < 150) requestAnimationFrame(draw);
      else {
        ctx.clearRect(0, 0, canvas!.width, canvas!.height);
        canvas!.classList.add('hidden');
      }
    }
    draw();
  }

  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement | null;
    if (!form) return;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const status = document.getElementById('form-status');
    if (!btn) return;

    btn.disabled = true;
    btn.textContent = 'Enviando...';

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (res.ok && json.success) {
        if (status) {
          status.textContent = '¡Mensaje enviado! Te responderé pronto.';
          status.className = 'text-center text-sm font-semibold py-2 px-4 rounded-lg bg-green-100 text-green-700';
        }
        form.reset();
        launchConfetti();
      } else {
        throw new Error(json.message || 'Error al enviar');
      }
    } catch (err) {
      if (status) {
        status.textContent = 'Hubo un error al enviar. Inténtalo de nuevo.';
        status.className = 'text-center text-sm font-semibold py-2 px-4 rounded-lg bg-red-100 text-red-700';
      }
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
      setTimeout(() => {
        if (status) status.className = 'hidden';
      }, 5000);
    }
  });
</script>